{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: BrigadeTramp.Api",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/server/BrigadeTramp.Api/bin/Debug/net10.0/BrigadeTramp.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/server/BrigadeTramp.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "preLaunchTask": "build-api"
    },
    {
      "name": "Client: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "preLaunchTask": "start-client"
    },
    {
      "name": "Client: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "preLaunchTask": "start-client"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API: BrigadeTramp.Api", "Client: Chrome"],
      "stopAll": true
    }
  ]
}
